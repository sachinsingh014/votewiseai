# ─────────────────────────────────────────────────────────────────────────────
# VoteWise AI — Backend Environment Variables
# Copy this to .env and fill in your values.
# In production: inject ALL secrets via Google Cloud Secret Manager — never hardcode.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080

# Comma-separated list of allowed CORS origins.
# Supports plain strings and /regex/ for dynamic preview URLs.
# Dev example:    http://localhost:5173
# Prod example:   https://votewiseai-94849.web.app,/^https:\/\/.*\.web\.app$/
ALLOWED_ORIGINS=http://localhost:5173

# ── Google Cloud ──────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=votewiseai-94849
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-2.5-flash

# Local dev only — in production, use Workload Identity Federation (no key file)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json

# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=votewiseai-94849

# Firebase web client config (used only if serving config server-side)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=votewiseai-94849.firebaseapp.com
FIREBASE_STORAGE_BUCKET=votewiseai-94849.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000    # 15 minutes
RATE_LIMIT_MAX=100             # requests per window
AI_RATE_LIMIT_WINDOW_MS=60000  # 1 minute
AI_RATE_LIMIT_MAX=10           # AI requests per minute

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL=3600                 # seconds (1 hour)

# ── Production-only (injected via Secret Manager in Cloud Run) ────────────────
# These are NEVER set here in .env — they come from Secret Manager at runtime.
# Listed here for documentation purposes only.
# GEMINI_API_KEY=               (Secret Manager: gemini-api-key)
